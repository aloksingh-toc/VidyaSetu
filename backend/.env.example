# ─────────────────────────────────────────────
# VidyaSetu — Environment Variables Template
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ─────────────────────────────────────────────

APP_PROFILE=dev

# Database (local dev — matches docker-compose.yml)
DATABASE_URL=jdbc:postgresql://localhost:5432/vidyasetu
DB_USERNAME=postgres
DB_PASSWORD=vidyasetu_dev

# JWT — generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=replace-with-256-bit-random-string
JWT_REFRESH_SECRET=replace-with-different-256-bit-random-string

# Cookie
COOKIE_SECURE=false
COOKIE_DOMAIN=localhost

# WhatsApp Business API (leave blank in dev — messaging is disabled)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_ENABLED=false

# SMS Fast2SMS (leave blank in dev)
FAST2SMS_API_KEY=
FAST2SMS_ENABLED=false

# Cloudflare R2 (leave blank in dev — PDFs saved locally)
R2_BUCKET_NAME=vidyasetu-dev
CF_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=

# Razorpay (use test keys from dashboard.razorpay.com)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Sentry (leave blank in dev)
SENTRY_DSN=

# AES-256 encryption key for WhatsApp token at rest (32-byte hex)
ENCRYPTION_KEY=replace-with-32-byte-hex-key
